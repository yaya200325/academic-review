{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagramDecision",
  "description": "Diagram type and rendering decision for a review section",
  "type": "object",
  "properties": {
    "section_title": { "type": "string" },
    "generate": {
      "type": "boolean",
      "description": "Whether to generate a diagram for this section"
    },
    "diagram_type": {
      "type": "string",
      "enum": ["flowchart", "sequence", "conceptual", "architecture", "none"],
      "description": "Type of diagram to generate"
    },
    "render_method": {
      "type": "string",
      "enum": ["mermaid", "dalle", "none"],
      "description": "mermaid for flow/sequence diagrams; dalle for conceptual/architectural"
    },
    "mermaid_code": {
      "type": ["string", "null"],
      "description": "Mermaid diagram source code (when render_method=mermaid)"
    },
    "dalle_prompt": {
      "type": ["string", "null"],
      "description": "Image generation prompt (when render_method=dalle)"
    },
    "caption": {
      "type": "string",
      "description": "Figure caption in the review's language"
    }
  },
  "required": ["section_title", "generate", "diagram_type", "render_method", "caption"]
}
